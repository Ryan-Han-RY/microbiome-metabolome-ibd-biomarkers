  transmute(
    output_type = "table",
    item = basename(final_path),
    path = final_path,
    status = case_when(
      status == "missing" ~ "missing",
      status == "exists_but_empty" ~ "empty_unexpected",
      status == "copied" ~ "ok",
      TRUE ~ status
    ),
    detail = paste0("n_rows=", n_rows, "; n_cols=", n_cols, "; expected_empty=", expected_empty)
  )

