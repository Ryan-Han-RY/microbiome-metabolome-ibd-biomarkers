message_header("Final output QC")

figure_qc <- figure_manifest %>%
  transmute(
    output_type = "figure",
    item = figure_title,
    path = final_path,
    status = case_when(
      status == "missing" ~ "missing",
      final_exists & !is.na(file_size_bytes) & file_size_bytes > 0 ~ "ok",
      TRUE ~ "problem"
    ),
    detail = paste0("figure_number=", figure_number, "; source=", source_path)
  )

