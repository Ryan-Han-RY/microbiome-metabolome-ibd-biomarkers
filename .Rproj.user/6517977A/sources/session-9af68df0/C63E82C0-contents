first_existing <- function(paths) {
  hit <- paths[file.exists(paths)]
  if (length(hit) == 0) {
    return(NA_character_)
  }
  hit[1]
}

copy_final_figure <- function(figure_number, title, output_name, candidates) {
  source_path <- first_existing(candidates)
  output_path <- file.path(final_fig_dir, output_name)
  
  if (!is.na(source_path)) {
    file.copy(source_path, output_path, overwrite = TRUE)
    status <- "copied"
  } else {
    status <- "missing"
  }
  
  tibble(
    figure_number = figure_number,
    figure_title = title,
    source_path = source_path,
    final_path = output_path,
    status = status
  )
}

