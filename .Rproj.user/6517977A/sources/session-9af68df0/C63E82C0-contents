copy_table <- function(source_path, output_name, expected_empty = FALSE) {
  output_path <- file.path(final_tab_dir, output_name)
  
  if (file.exists(source_path)) {
    file.copy(source_path, output_path, overwrite = TRUE)
    dat <- read_tsv_if_exists(source_path)
    status <- if_else(nrow(dat) == 0 && !expected_empty, "exists_but_empty", "copied")
    n_rows <- nrow(dat)
    n_cols <- ncol(dat)
  } else {
    status <- "missing"
    n_rows <- NA_integer_
    n_cols <- NA_integer_
  }
  
  tibble(
    source_path = source_path,
    final_path = output_path,
    status = status,
    n_rows = n_rows,
    n_cols = n_cols,
    expected_empty = expected_empty
  )
}

